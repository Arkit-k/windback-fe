{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": ["BACKEND_URL", "NEXT_PUBLIC_SITE_URL", "NEXT_PUBLIC_BACKEND_URL", "NEXT_PUBLIC_DOCS_URL", "NEXT_PUBLIC_SUPPORT_EMAIL", "NEXT_PUBLIC_APP_NAME", "SENTRY_ORG", "SENTRY_PROJECT"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    }
  }
}
